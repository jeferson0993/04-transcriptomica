# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
TRANSCRIPTOMICS_DB=transcriptomics

# MinIO (object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed
MINIO_BUCKET_CURATED=curated

# Transcriptomics
REF_DIR=/ref
WORKSPACE=/workspace
PIPELINE_DIR=/pipeline
WORKER_CONTAINER=transcriptomics-worker
# Default Nextflow profile(s) (comma-separated): docker,eco | docker,micro | docker,slim | docker
# eco: <8GB RAM | micro: <4GB RAM | slim: <12GB RAM
DEFAULT_PROFILE=docker,eco

# Rate limiting
MAX_CONCURRENT_RUNS=2

# Data Lake integration
DATALAKE_API_URL=http://api-data-lake:8000

# Domain (CORS)
DOMAIN=localhost

# Logging
LOG_LEVEL=INFO
