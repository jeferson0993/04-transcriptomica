params {
    star_extra_args = "--genomeLoad NoSharedMemory --outBAMcompression 10 --outSAMtype BAM Unsorted --outFilterMismatchNmax 1 --outFilterMultimapNmax 10 --outSAMunmapped None --outSAMattributes All "
    star_index = "/ref/grch38/star_index_micro"
    deseq2_cooks_cutoff = false
    max_cpus = 2
    max_memory = 4.GB
}

process {
    withLabel: process_high {
        cpus = 2
        memory = 3.GB
    }
    withLabel: process_medium {
        cpus = 1
        memory = 2.GB
    }
    withLabel: process_low {
        cpus = 1
        memory = 1.GB
    }

    withName: STAR_ALIGN {
        cpus = 2
        memory = 3.GB
        time = 72.h
    }
    withName: TRIMMING {
        cpus = 1
        memory = 2.GB
    }
    withName: FEATURECOUNTS {
        cpus = 1
        memory = 2.GB
    }
    withName: DESEQ2 {
        cpus = 1
        memory = 2.GB
    }
    withName: FASTQC {
        cpus = 1
        memory = 1.GB
    }
    withName: MULTIQC {
        cpus = 1
        memory = 1.GB
    }

    maxRetries = 5
    errorStrategy = { task.exitStatus in [137, 139, 143] ? 'retry' : 'terminate' }
    queueSize = 1
}
